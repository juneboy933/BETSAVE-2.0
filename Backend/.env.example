PORT=5000
MONGO_URI=mongodb://localhost:27017/betsave
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_INITIAL_CONNECT_RETRIES=10
MONGO_INITIAL_CONNECT_RETRY_DELAY_MS=3000
REDIS_URI=redis://localhost:6379
SAVINGS_PERCENTAGE=0.1

# Partner integration mode:
# demo = allows manual demo/testing from partner dashboard
# live = blocks manual partner write actions unless x-integration-token is provided
PARTNER_OPERATING_MODE=demo
PARTNER_INTEGRATION_TOKEN=

# Admin middleware
ADMIN_DASHBOARD_TOKEN=your_secure_admin_token

# Optional operations readiness flags
BANK_API_URL=
BANK_API_KEY=
BANK_SETTLEMENT_ACCOUNT=

# Payment callback protection
PAYMENT_CALLBACK_TOKEN=
PAYMENTS_ENABLE_DEPOSITS=true
PAYMENTS_ENABLE_WITHDRAWALS=true
WITHDRAWAL_MIN_KES=100
# Partner event STK flow is always enforced in demo/live modes.

# Daraja
DARAJA_ENV=sandbox
DARAJA_HTTP_TIMEOUT_MS=15000
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=

# STK collection
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_STK_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_STK_CALLBACK_URL=

# B2C disbursement
DARAJA_B2C_SHORTCODE=
DARAJA_B2C_INITIATOR_NAME=
DARAJA_B2C_SECURITY_CREDENTIAL=
DARAJA_B2C_COMMAND_ID=BusinessPayment
DARAJA_B2C_TIMEOUT_URL=
DARAJA_B2C_RESULT_URL=
