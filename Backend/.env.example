PORT=5000
MONGO_URI=mongodb://localhost:27017/betsave
MONGO_REQUIRE_TRANSACTIONS=false
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_INITIAL_CONNECT_RETRIES=10
MONGO_INITIAL_CONNECT_RETRY_DELAY_MS=3000
REDIS_URI=redis://localhost:6379
SAVINGS_PERCENTAGE=0.1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
PARTNER_WEBHOOK_TIMEOUT_MS=5000
OPERATIONAL_RECOVERY_INTERVAL_MS=60000
RECOVERY_BATCH_SIZE=100
STALE_PROCESSING_EVENT_MS=600000
STALE_INITIATED_PAYMENT_MS=300000
STALE_PENDING_PAYMENT_MS=1800000
STALE_SETTLEMENT_MS=86400000

# Partner integration mode:
# demo = allows manual demo/testing from partner dashboard
# live = blocks manual partner write actions unless x-integration-token is provided
PARTNER_OPERATING_MODE=demo
PARTNER_INTEGRATION_TOKEN=
PARTNER_JWT_SECRET=
PARTNER_SECRET_ENCRYPTION_KEY=

# Admin authentication
ADMIN_DASHBOARD_TOKEN=
ADMIN_TOKEN_TTL_HOURS=12
USER_JWT_SECRET=
USER_JWT_EXPIRATION=7d
USER_SELF_REGISTRATION_ENABLED=false

# Optional operations readiness flags
BANK_API_URL=
BANK_API_KEY=
BANK_SETTLEMENT_ACCOUNT=

# Payment callback protection
PAYMENT_CALLBACK_TOKEN=
# Betsave derives per-transaction signed Daraja callback URLs from PAYMENT_CALLBACK_TOKEN.
PAYMENTS_ENABLE_DEPOSITS=true
PAYMENTS_ENABLE_WITHDRAWALS=true
LIVE_WITHDRAWAL_MIN_BALANCE_KES=100
LIVE_WITHDRAWAL_MIN_AUTOSAVINGS_DAYS=90
# Demo withdrawals are allowed whenever the wallet has sufficient balance.
# Live withdrawals require at least LIVE_WITHDRAWAL_MIN_BALANCE_KES in wallet balance
# and a live auto-savings relationship that has been enabled for
# LIVE_WITHDRAWAL_MIN_AUTOSAVINGS_DAYS days.

# Daraja
DARAJA_ENV=sandbox
DARAJA_HTTP_TIMEOUT_MS=15000
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=

# STK collection
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_STK_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_STK_CALLBACK_URL=

# B2C disbursement
DARAJA_B2C_SHORTCODE=
DARAJA_B2C_INITIATOR_NAME=
DARAJA_B2C_SECURITY_CREDENTIAL=
DARAJA_B2C_COMMAND_ID=BusinessPayment
# Suggested callbacks:
# DARAJA_B2C_TIMEOUT_URL=https://your-domain/api/v1/payments/callbacks/b2c/queue
# DARAJA_B2C_RESULT_URL=https://your-domain/api/v1/payments/callbacks/b2c/result
DARAJA_B2C_TIMEOUT_URL=
DARAJA_B2C_RESULT_URL=
